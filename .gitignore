# ==========================================
# LifeLog Project .gitignore
# ==========================================

# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Dependencies & Environments ---
node_modules/
venv/
env/
.env
.env.local
.env.production
.env.development
.env.*.local
! .env.example

# --- Build Outputs ---
dist/
dist-ssr/
build/
target/
*.exe
*.dll
*.so
*.dylib

# --- Python ---
__pycache__/
.pytest_cache/
.coverage
.ipynb_checkpoints
*.pyc
*.pyo
*.pyd

# --- Database & Large Data ---
# 忽略数据库文件及数据库运行时产生的临时文件
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal
backend/data/*.bak
data/

# --- IDE / Editor ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# --- OS Specific ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Agent & AI Tools ---
.agent/
.gemini/
brain/
desc/
design-system/
# 注意：如果 desc/ 下有你想要保留的文档，可以视情况取消忽略
# !desc/*.md
